{
    "name": "mnb/scraperkit",
    "description": "MNB ScraperKit V4.1.1 - enterprise-ready PHP crawling and data extraction framework with safe academic publisher metadata crawling, article DOI/ISSN normalization, source connectors, CLI/API/dashboard workflows, datasets, evaluation, security compliance, and export automation.",
    "type": "library",
    "license": "MIT",
    "version": "4.1.1",
    "require": {
        "php": ">=8.2",
        "ext-dom": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "symfony/console": "^6.4 || ^7.0"
    },
    "suggest": {
        "ext-curl": "Recommended for the cURL HTTP engine. The stream/file_get_contents engine works without cURL when allow_url_fopen is enabled.",
        "ext-pdo": "Needed only for database storage features.",
        "symfony/panther": "Optional browser-assisted crawling adapter for JavaScript-rendered pages. Normal PHP HTTP crawling works without it.",
        "chrome/chromium": "Needed only when using browser-assisted crawling through Panther/Chrome.",
        "pdo_sqlite": "Optional SQLite driver for local database storage.",
        "pdo_mysql": "Optional MySQL/MariaDB driver for server database storage.",
        "php-ai/php-ml": "Optional machine-learning toolkit for future model training/inference. V4.1.1 includes deterministic ML-ready features, dataset annotations, evaluation reports, rule-builder assisted profile creation, training-ready exports, and export connector delivery manifests without requiring this dependency.",
        "ext-redis": "Optional Redis extension for distributed multi-worker queue mode. File-based distributed queue fallback works without Redis.",
        "ext-openssl": "Recommended for secure HTTPS transport and checksum/signature workflows."
    },
    "autoload": {
        "psr-4": {
            "Mnb\\ScraperKit\\": "src/"
        }
    },
    "bin": [
        "bin/mnb-scraper"
    ],
    "scripts": {
        "test": "php -d zend.assertions=1 -d assert.exception=1 tests/run-tests.php",
        "scraper:list": "php bin/mnb-scraper list",
        "ci:check": "php bin/mnb-scraper ci:check --strict",
        "release:check": "php bin/mnb-scraper release:check --strict",
        "benchmark": "php bin/mnb-scraper benchmark:run --iterations=1000"
    },
