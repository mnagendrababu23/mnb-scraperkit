{
  "search_provider_version": "1.0.0",
  "default_provider": "offline",
  "do_not_scrape_search_result_pages": true,
  "providers": {
    "google_custom_search": {
      "enabled": false,
      "env_api_key": "GOOGLE_CUSTOM_SEARCH_API_KEY",
      "env_engine_id": "GOOGLE_CUSTOM_SEARCH_ENGINE_ID"
    },
    "azure_bing_grounding": {
      "enabled": false,
      "env_api_key": "AZURE_BING_SEARCH_KEY",
      "env_endpoint": "AZURE_BING_ENDPOINT"
    },
    "offline": {
      "enabled": true,
      "notes": "Import approved search result JSON or generate deterministic seed suggestions."
    }
  }
}
